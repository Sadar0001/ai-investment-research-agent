# ==================================================================
# InvestIQ AI - Environment Configuration
# Copy this file to `.env` and fill in your actual keys.
# Keys left blank will cause the related tool to gracefully degrade
# (agents fall back to alternate sources instead of crashing).
# ==================================================================

# --- Required for all LLM-powered agents ---
OPENAI_API_KEY=

# --- Optional: LangSmith tracing/observability ---
LANGSMITH_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=InvestIQ

# --- Optional data source keys (recommended, not required) ---
TAVILY_API_KEY=
NEWS_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
SERPAPI_API_KEY=

# --- App configuration ---
APP_ENV=development
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=3600
REQUEST_TIMEOUT_SECONDS=20
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
